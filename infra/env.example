# ─────────────────────────────────────────────────────────────────────────────
# MM-MARAS Dashboard — environment variables
# Copy to infra/.env and fill in values before running docker compose.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mmaras

# ── Auth ──────────────────────────────────────────────────────────────────────
# Random 32+ char string — used as the admin Bearer token
ADMIN_TOKEN=changeme-admin-token

# Random 64+ char string — used by itsdangerous for subscription tokens
SECRET_KEY=changeme-secret-key-at-least-64-chars-long

# ── Email (SendGrid SMTP relay) ───────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.your-sendgrid-api-key
SMTP_FROM=noreply@yourdomain.com

# ── For local dev: point SMTP at mailpit instead ─────────────────────────────
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your-twilio-auth-token
TWILIO_FROM=+1xxxxxxxxxx

# ── Data ingestion ────────────────────────────────────────────────────────────
CMEMS_USERNAME=your-cmems-username
CMEMS_PASSWORD=your-cmems-password
CDSAPI_KEY=your-cds-api-key

# ── Paths ─────────────────────────────────────────────────────────────────────
# Which checkpoint file to load (relative to model/checkpoints/ inside container)
CHECKPOINT_FILE=best.pt

# Host path for checkpoint backups (mounted as /backups in worker)
CHECKPOINT_BACKUP_DIR=./data/backups

# ── Public URL (used in notification links) ───────────────────────────────────
PUBLIC_BASE_URL=https://yourdomain.com
